# Flask secret key — sign and encrypt session cookies.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=yoursecretkeyhere_make_it_long_and_random

# True = development mode (auto-reload, debugger). False = production.
DEBUG=True
