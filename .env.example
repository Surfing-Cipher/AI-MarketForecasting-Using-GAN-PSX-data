# =====================================================================
# NEXUS AI — Environment Variable Template
# =====================================================================
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
# WARNING: Ensure your .env file is added to .gitignore!
# Never commit your actual .env file to version control.
# =====================================================================

# Flask secret key — sign and encrypt session cookies.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=REPLACE_WITH_ACTUAL_SECRET_KEY

# Set to True ONLY in your local development environment.
# Never set to True in production — Flask's debugger exposes a Python
# console in the browser that allows arbitrary code execution.
DEBUG=False
